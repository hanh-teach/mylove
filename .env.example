# ==============================================================================
# ENTERPRISE REVOLUTIONARY GREETING CARD - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' and adjust variables to suit your environment needs.
# The server will read variables from the environment or from the '.env' file.
# Note: Missing API keys will NOT crash the server, but will trigger warning logs.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE SYSTEM CONFIGURATION
# ------------------------------------------------------------------------------

# NODE_ENV: Defines the current stage of the system.
# Values: 'development', 'staging', 'production'
# Default: 'development'
NODE_ENV=development

# PORT: The port that the web application server binds to.
# Note: Must be 3000 in this workspace environment for container ingress routing.
# Default: 3000
PORT=3000

# CACHE_TTL_SECONDS: The configuration Time-to-Live (TTL) for cached items.
# Used for AI Response, Prompts, Templates, and Metadata Caching to save AI billing costs.
# Default: 1800 (30 minutes)
CACHE_TTL_SECONDS=1800


# ------------------------------------------------------------------------------
# 2. GEMINI REASONING ENGINE
# ------------------------------------------------------------------------------

# GEMINI_API_KEY: Standard API credential key for Google Gemini model services.
# Used for server-side semantic message/card text generation.
# Default: (Empty)
GEMINI_API_KEY=


# ------------------------------------------------------------------------------
# 3. VIDEO & ANIMATION PROVIDERS
# ------------------------------------------------------------------------------

# AGNES_API_BASE: Primary endpoint base URL for the Agnes AI image/video pipeline.
# Default: 'https://apihub.agnes-ai.com'
AGNES_API_BASE=https://apihub.agnes-ai.com

# AGNES_API_KEY: Bearer authentication key for the Agnes AI image/video engine.
# Also supports alias 'VIDEO_KEY_API'.
# Default: (Empty)
AGNES_API_KEY=

# FAL_KEY: Security credential token for FAL-AI (Pika-based video model integration).
# Default: (Empty)
FAL_KEY=

# RUNWAY_API_KEY: Developer API key for RunwayML (used for image-to-video animation).
# Default: (Empty)
RUNWAY_API_KEY=

# hugging_API_KEY: Private developer auth token for Hugging Face Inference API.
# Used for image rendering (e.g. FLUX.1-schnell model).
# Also supports alias 'HUGGINGFACE_API_KEY' or 'HUGGING_API_KEY'.
# Default: (Empty)
hugging_API_KEY=
